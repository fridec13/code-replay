{
  "name": "code-replay",
  "displayName": "Code Replay",
  "description": "Record and replay code execution with function highlights, variable decorations, and a timeline panel.",
  "version": "0.1.2",
  "publisher": "fridec13",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Debuggers", "Visualization"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fridec13/code-replay"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:codeReplay.recordPython",
    "onCommand:codeReplay.recordJS",
    "onCommand:codeReplay.recordCpp",
    "onCommand:codeReplay.liveMode",
    "onCommand:codeReplay.openTimeline",
    "onView:codeReplay.timeline"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeReplay.recordPython",
        "title": "Code Replay: Record Python File",
        "icon": "$(record)"
      },
      {
        "command": "codeReplay.recordJS",
        "title": "Code Replay: Record JS/TS File",
        "icon": "$(record)"
      },
      {
        "command": "codeReplay.recordCpp",
        "title": "Code Replay: Record C/C++ File",
        "icon": "$(record)"
      },
      {
        "command": "codeReplay.liveMode",
        "title": "Code Replay: Attach Live Mode (DAP)",
        "icon": "$(debug-alt)"
      },
      {
        "command": "codeReplay.openTimeline",
        "title": "Code Replay: Open Timeline",
        "icon": "$(timeline-view-icon)"
      },
      {
        "command": "codeReplay.playPause",
        "title": "Code Replay: Play / Pause",
        "icon": "$(play)"
      },
      {
        "command": "codeReplay.stop",
        "title": "Code Replay: Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "codeReplay.setSpeed",
        "title": "Code Replay: Set Playback Speed"
      },
      {
        "command": "codeReplay.playPauseKeyboard",
        "title": "Code Replay: Play / Pause (Keyboard)"
      }
    ],
    "keybindings": [
      {
        "command": "codeReplay.playPauseKeyboard",
        "key": "ctrl+shift+space",
        "mac": "cmd+shift+space",
        "when": "editorFocus || webviewFocus"
      },
      {
        "command": "codeReplay.recordPython",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorLangId == python"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "codeReplay.recordPython",
          "when": "resourceExtname == .py",
          "group": "navigation"
        },
        {
          "command": "codeReplay.recordJS",
          "when": "resourceExtname =~ /\\.(js|ts|mjs|cjs)$/",
          "group": "navigation"
        },
        {
          "command": "codeReplay.recordCpp",
          "when": "resourceExtname =~ /\\.(cpp|c|cc|cxx)$/",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeReplayContainer",
          "title": "Code Replay",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codeReplayContainer": [
        {
          "type": "webview",
          "id": "codeReplay.timeline",
          "name": "Code Replay Timeline"
        }
      ]
    },
    "configuration": {
      "title": "Code Replay",
      "properties": {
        "codeReplay.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to the Python executable used for recording."
        },
        "codeReplay.nodePath": {
          "type": "string",
          "default": "node",
          "description": "Path to the Node.js executable used for recording."
        },
        "codeReplay.defaultSpeed": {
          "type": "number",
          "default": 1,
          "description": "Default playback speed multiplier."
        },
        "codeReplay.maxEventsPerTrace": {
          "type": "number",
          "default": 100000,
          "description": "Maximum number of trace events to collect per run."
        },
        "codeReplay.gppPath": {
          "type": "string",
          "default": "g++",
          "description": "Path to the g++ compiler used for C/C++ recording. Set this if g++ is not on your PATH (e.g. C:\\msys64\\mingw64\\bin\\g++.exe)."
        },
        "codeReplay.gdbPath": {
          "type": "string",
          "default": "gdb",
          "description": "Path to the GDB debugger used for C/C++ recording. Set this if gdb is not on your PATH (e.g. C:\\msys64\\mingw64\\bin\\gdb.exe)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  }
}
